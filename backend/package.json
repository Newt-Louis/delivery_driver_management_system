{
  "name": "mall-delivery-backend",
  "version": "1.0.0",
  "description": "AI Delivery Scheduling & Yard Management System - Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "seed": "tsx prisma/seed.ts",
    "test:concurrency": "node --import tsx --test src/tests/concurrency.test.ts",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "prisma": "6.19.3",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express": "4.18.2",
    "jsonwebtoken": "9.0.2",
    "socket.io": "4.7.4",
    "web-push": "3.6.7",
    "zod": "3.22.4",
    "tsx": "4.7.0"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.0.0",
    "typescript": "^5.3.3"
  }
}
