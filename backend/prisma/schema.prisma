generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN
  ADMIN_LOC
  ADMIN_OPE
  RECEIVING
  CHECKIN
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ReceivingUnit {
  EMART
  THISKYHALL
  TENANT
}

enum GoodsType {
  FRESH_FOOD
  AUTO_WAREHOUSE
  GENERAL_GOODS
  THI_CONG
}

enum VehicleType {
  TRUCK
  MOTORBIKE
  OTHER
}

enum DeviceType {
  FIXED_DEVICE
  PDA
  TABLET
  TV
}

enum AuditActorType {
  USER
  STAFF
  DEVICE
  SYSTEM
}

enum DeliveryStatus {
  REGISTERED
  WAITING
  CALLED
  RECEIVING
  AUTO_WAREHOUSE_RECEIVING
  COMPLETED
  CANCELLED
  EXPIRED // auto-archived: past-day no-checkin or no-delivery
  INCOMPLETED
}

enum DeliveryHistoryFinalStatus {
  COMPLETED
  CANCELLED
  EXPIRED
  INCOMPLETED
}

enum DeliveryHistoryEventType {
  REGISTERED
  CHECKED_IN
  AUTO_ASSIGNED
  MANUAL_CALLED
  RECALLED
  REASSIGNED_SLOT
  RECEIVING_STARTED
  AUTO_WAREHOUSE_RECEIVING_STARTED
  COMPLETED
  CANCELLED
  EXPIRED_NO_SHOW
  EXPIRED_WAITING
  INCOMPLETED
  ARCHIVED
}

enum SchedulerJobStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum SchedulerJobTrigger {
  SCHEDULED
  MANUAL
  STARTUP
}

model User {
  id                 String               @id @default(cuid())
  name               String
  email              String               @unique
  passwordHash       String               @map("password_hash")
  role               Role                 @default(CHECKIN)
  unit               ReceivingUnit? // optional unit assignment
  department         String? // free-text department / shift label
  businessLocationId String?              @map("business_location_id")
  businessLocation   BusinessLocation?    @relation(fields: [businessLocationId], references: [id])
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at")
  faceCredentials    FaceCredential[]
  authChallenges     AuthChallenge[]
  unitPermissions    UserUnitPermission[]

  @@index([businessLocationId, role, isActive])
  @@map("users")
}

model UserUnitPermission {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitConfigId String     @map("unit_config_id")
  unitConfig   UnitConfig @relation(fields: [unitConfigId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, unitConfigId])
  @@index([unitConfigId])
  @@map("user_unit_permissions")
}

model AppConfig {
  id                String   @id @default(cuid())
  key               String   @unique
  category          String
  value             Json
  valueType         String   @default("json") @map("value_type")
  description       String   @default("")
  isSensitive       Boolean  @default(false) @map("is_sensitive")
  isRuntimeEditable Boolean  @default(true) @map("is_runtime_editable")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("app_configs")
}

model FaceCredential {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique @map("credential_id")
  publicKey    Json      @map("public_key")
  signCount    Int       @default(0) @map("sign_count")
  deviceName   String?   @map("device_name")
  transports   String[]  @default([])
  isActive     Boolean   @default(true) @map("is_active")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId, isActive])
  @@map("face_credentials")
}

model AuthChallenge {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge  String    @unique
  type       String
  metadata   Json?
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId, type, expiresAt])
  @@map("auth_challenges")
}

model Zone {
  id           String     @id @default(cuid())
  code         String
  name         String
  unitConfigId String     @map("unit_config_id")
  unitConfig   UnitConfig @relation(fields: [unitConfigId], references: [id])
  slots        Slot[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([unitConfigId, code])
  @@index([unitConfigId])
  @@map("zones")
}

model Slot {
  id                String                 @id @default(cuid())
  code              String                 @unique // T1, T2, M1, M2 …
  name              String
  assignedUnit      ReceivingUnit          @map("assigned_unit")
  vehicleType       VehicleType            @default(TRUCK) @map("vehicle_type")
  acceptedGoods     GoodsType[]            @default([]) @map("accepted_goods") // empty = accepts all goods
  autoAssign        Boolean                @default(true) @map("auto_assign")
  autoWarehouseOnly Boolean                @default(false) @map("auto_warehouse_only")
  maxCapacity       Int                    @default(1) @map("max_capacity")
  status            SlotStatus             @default(AVAILABLE)
  isActive          Boolean                @default(true) @map("is_active")
  currentDeliveryId String?                @map("current_delivery_id")
  lastUsedAt        DateTime?              @map("last_used_at")
  zoneId            String                 @map("zone_id")
  zone              Zone                   @relation(fields: [zoneId], references: [id])
  deliveries        DeliveryRegistration[] @relation("AssignedSlot")

  @@index([zoneId])
  @@index([assignedUnit, vehicleType, status, isActive, autoAssign])
  @@index([zoneId, vehicleType, status, isActive, autoAssign])
  @@map("slots")
}

model DeliveryRegistration {
  id                 String                 @id @default(cuid())
  registrationCode   String                 @unique @map("registration_code")
  vendorName         String                 @map("vendor_name")
  driverName         String                 @map("driver_name")
  driverPhone        String                 @map("driver_phone")
  vehiclePlate       String                 @map("vehicle_plate")
  receivingUnit      ReceivingUnit          @map("receiving_unit")
  goodsType          GoodsType              @map("goods_type")
  poNumber           String?                @map("po_number")
  vendorCode         String?                @map("vendor_code")
  requestedTime      DateTime?              @map("requested_time")
  checkinTime        DateTime?              @map("checkin_time")
  calledTime         DateTime?              @map("called_time")
  receivingStartTime DateTime?              @map("receiving_start_time")
  completedTime      DateTime?              @map("completed_time")
  status             DeliveryStatus         @default(REGISTERED)
  assignedSlotId     String?                @map("assigned_slot_id")
  assignedSlot       Slot?                  @relation("AssignedSlot", fields: [assignedSlotId], references: [id])
  vehicleType        VehicleType            @default(OTHER) @map("vehicle_type")
  autoWarehouse      Boolean                @default(false) @map("auto_warehouse")
  ticketNumber       Int?                   @map("ticket_number")
  note               String?
  cancelReason       String?                @map("cancel_reason")
  unitGoodsTypeId    String?                @map("unit_goods_type_id")
  unitGoodsType      UnitGoodsType?         @relation(fields: [unitGoodsTypeId], references: [id], onDelete: SetNull)
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  historyEvents      DeliveryHistoryEvent[]

  @@index([status, receivingUnit, vehicleType, checkinTime])
  @@index([assignedSlotId, status])
  @@index([vehiclePlate, createdAt])
  @@index([requestedTime])
  @@index([createdAt])
  @@map("delivery_registrations")
}

model TicketSequence {
  id            String        @id @default(cuid())
  ticketDate    String        @map("ticket_date")
  receivingUnit ReceivingUnit @map("receiving_unit")
  vehicleType   VehicleType   @map("vehicle_type")
  nextNumber    Int           @default(1) @map("next_number")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@unique([ticketDate, receivingUnit, vehicleType])
  @@index([receivingUnit, vehicleType, ticketDate])
  @@map("ticket_sequences")
}

model RegistrationSequence {
  id               String        @id @default(cuid())
  registrationDate String        @map("registration_date")
  receivingUnit    ReceivingUnit @map("receiving_unit")
  nextNumber       Int           @default(1) @map("next_number")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@unique([registrationDate, receivingUnit])
  @@index([receivingUnit, registrationDate])
  @@map("registration_sequences")
}

model AuditLog {
  id                 String         @id @default(cuid())
  actorType          AuditActorType @map("actor_type")
  actorId            String?        @map("actor_id")
  actorLabel         String?        @map("actor_label")
  businessLocationId String?        @map("business_location_id")
  unitConfigId       String?        @map("unit_config_id")
  action             String
  targetType         String         @map("target_type")
  targetId           String?        @map("target_id")
  before             Json?
  after              Json?
  metadata           Json?
  requestId          String?        @map("request_id")
  createdAt          DateTime       @default(now()) @map("created_at")

  @@index([businessLocationId, createdAt])
  @@index([unitConfigId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorType, actorId, createdAt])
  @@map("audit_logs")
}

model DeliveryHistory {
  id                       String                     @id @default(cuid())
  originalDeliveryId       String                     @unique @map("original_delivery_id")
  registrationCode         String                     @unique @map("registration_code")
  businessLocationId       String?                    @map("business_location_id")
  unitConfigId             String?                    @map("unit_config_id")
  receivingUnit            ReceivingUnit              @map("receiving_unit")
  vendorName               String                     @map("vendor_name")
  vendorCode               String?                    @map("vendor_code")
  poNumber                 String?                    @map("po_number")
  driverName               String                     @map("driver_name")
  driverPhone              String                     @map("driver_phone")
  vehiclePlate             String                     @map("vehicle_plate")
  goodsType                GoodsType                  @map("goods_type")
  unitGoodsTypeId          String?                    @map("unit_goods_type_id")
  vehicleType              VehicleType                @map("vehicle_type")
  autoWarehouse            Boolean                    @default(false) @map("auto_warehouse")
  requestedTime            DateTime?                  @map("requested_time")
  registeredAt             DateTime                   @map("registered_at")
  checkinTime              DateTime?                  @map("checkin_time")
  calledTime               DateTime?                  @map("called_time")
  receivingStartTime       DateTime?                  @map("receiving_start_time")
  completedTime            DateTime?                  @map("completed_time")
  finalStatus              DeliveryHistoryFinalStatus @map("final_status")
  closeReason              String?                    @map("close_reason")
  ticketNumber             Int?                       @map("ticket_number")
  assignedSlotId           String?                    @map("assigned_slot_id")
  assignedSlotCode         String?                    @map("assigned_slot_code")
  assignedSlotName         String?                    @map("assigned_slot_name")
  callCount                Int                        @default(0) @map("call_count")
  lastCalledAt             DateTime?                  @map("last_called_at")
  cancelledAt              DateTime?                  @map("cancelled_at")
  expiredAt                DateTime?                  @map("expired_at")
  archivedAt               DateTime                   @default(now()) @map("archived_at")
  archivedByJobRunId       String?                    @map("archived_by_job_run_id")
  durationWaitingMinutes   Int?                       @map("duration_waiting_minutes")
  durationReceivingMinutes Int?                       @map("duration_receiving_minutes")
  note                     String?
  metadata                 Json?
  events                   DeliveryHistoryEvent[]
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")

  @@index([businessLocationId, archivedAt])
  @@index([unitConfigId, archivedAt])
  @@index([finalStatus, archivedAt])
  @@index([requestedTime])
  @@index([vehiclePlate, archivedAt])
  @@map("delivery_history")
}

model DeliveryHistoryEvent {
  id                     String                   @id @default(cuid())
  deliveryHistoryId      String?                  @map("delivery_history_id")
  deliveryHistory        DeliveryHistory?         @relation(fields: [deliveryHistoryId], references: [id], onDelete: Cascade)
  deliveryRegistrationId String?                  @map("delivery_registration_id")
  deliveryRegistration   DeliveryRegistration?    @relation(fields: [deliveryRegistrationId], references: [id], onDelete: SetNull)
  originalDeliveryId     String                   @map("original_delivery_id")
  registrationCode       String                   @map("registration_code")
  businessLocationId     String?                  @map("business_location_id")
  unitConfigId           String?                  @map("unit_config_id")
  eventType              DeliveryHistoryEventType @map("event_type")
  fromStatus             DeliveryStatus?          @map("from_status")
  toStatus               DeliveryStatus?          @map("to_status")
  occurredAt             DateTime                 @default(now()) @map("occurred_at")
  actorType              AuditActorType?          @map("actor_type")
  actorId                String?                  @map("actor_id")
  actorLabel             String?                  @map("actor_label")
  slotId                 String?                  @map("slot_id")
  slotCode               String?                  @map("slot_code")
  slotName               String?                  @map("slot_name")
  message                String?
  reason                 String?
  metadata               Json?
  createdAt              DateTime                 @default(now()) @map("created_at")

  @@index([deliveryHistoryId, occurredAt])
  @@index([deliveryRegistrationId, occurredAt])
  @@index([originalDeliveryId, occurredAt])
  @@index([registrationCode, occurredAt])
  @@index([businessLocationId, occurredAt])
  @@index([unitConfigId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("delivery_history_events")
}

model SchedulerJobHistory {
  id             String              @id @default(cuid())
  jobName        String              @map("job_name")
  businessDate   String?             @map("business_date")
  timezone       String              @default("Asia/Ho_Chi_Minh")
  trigger        SchedulerJobTrigger @default(SCHEDULED)
  status         SchedulerJobStatus  @default(RUNNING)
  startedAt      DateTime            @default(now()) @map("started_at")
  finishedAt     DateTime?           @map("finished_at")
  processedCount Int                 @default(0) @map("processed_count")
  succeededCount Int                 @default(0) @map("succeeded_count")
  failedCount    Int                 @default(0) @map("failed_count")
  metadata       Json?
  errorMessage   String?             @map("error_message")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([jobName, startedAt])
  @@index([businessDate, jobName])
  @@index([status, startedAt])
  @@map("scheduler_job_histories")
}

model UnitConfig {
  id                 String               @id @default(cuid())
  unit               ReceivingUnit
  businessLocationId String               @map("business_location_id")
  businessLocation   BusinessLocation     @relation(fields: [businessLocationId], references: [id])
  zones              Zone[]
  userPermissions    UserUnitPermission[]

  // FRESH FOOD
  freshFoodEnabled Boolean @default(true) @map("fresh_food_enabled")

  // GENERAL GOODS
  generalGoodsEnabled Boolean @default(true) @map("general_goods_enabled")

  // THI CONG
  thiCongEnabled Boolean @default(true) @map("thi_cong_enabled")

  sundayFreshFoodOnly Boolean @default(false) @map("sunday_fresh_food_only")

  //SLOT
  truckSlotMinutes     Int @default(30) @map("truck_slot_minutes")
  motorbikeSlotMinutes Int @default(15) @map("motorbike_slot_minutes")
  truckMaxPerSlot      Int @default(1) @map("truck_max_per_slot")
  motorbikeMaxPerSlot  Int @default(3) @map("motorbike_max_per_slot")

  // INTEGRATIONS
  vendorApiUrl String? @map("vendor_api_url")
  vendorApiKey String? @map("vendor_api_key")
  poApiUrl     String? @map("po_api_url")
  poApiKey     String? @map("po_api_key")

  // BRANDING
  displayName  String  @default("") @map("display_name")
  shortName    String  @default("") @map("short_name")
  description  String  @default("") @map("description")
  icon         String? @map("icon")
  logoUrl      String? @map("logo_url")
  primaryColor String  @default("#1C1C1C") @map("primary_color")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessLocationId, unit])
  @@index([businessLocationId])
  @@map("unit_configs")
}

model Device {
  id                 String           @id @default(cuid())
  code               String           @unique
  name               String
  businessLocationId String           @map("business_location_id")
  businessLocation   BusinessLocation @relation(fields: [businessLocationId], references: [id])
  deviceType         DeviceType       @default(FIXED_DEVICE) @map("device_type")
  deviceSecretHash   String           @map("device_secret_hash")
  isActive           Boolean          @default(true) @map("is_active")
  lastSeenAt         DateTime?        @map("last_seen_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([businessLocationId, deviceType, isActive])
  @@map("devices")
}

model BusinessLocation {
  id           String       @id @default(cuid())
  code         String       @unique
  locationName String       @default("THISO GROUP") @map("location_name")
  address      String       @default("")
  avatarUrl    String?      @map("avatar_url")
  logoUrl      String?      @map("logo_url")
  tagline      String?      @default("Delivery Management System")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  unitConfigs  UnitConfig[]
  users        User[]
  devices      Device[]

  @@map("business_locations")
}

model AutoWarehouseVendor {
  id         String        @id @default(cuid())
  unit       ReceivingUnit
  vendorCode String        @map("vendor_code")
  vendorName String        @map("vendor_name")
  active     Boolean       @default(true)
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@unique([unit, vendorCode])
  @@map("auto_warehouse_vendors")
}

model PushSubscription {
  id           String   @id @default(cuid())
  endpoint     String   @unique
  p256dh       String
  auth         String
  deliveryCode String   @map("delivery_code")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([deliveryCode])
  @@map("push_subscriptions")
}

model ReceivingTimeConfig {
  id                 String        @id @default(cuid())
  unit               ReceivingUnit
  vehicleType        VehicleType   @map("vehicle_type")
  goodsType          GoodsType     @map("goods_type")
  configuredMinutes  Float         @default(30) @map("configured_minutes")
  recommendedMinutes Float?        @map("recommended_minutes")
  sampleCount        Int           @default(0) @map("sample_count")
  lastAnalyzedAt     DateTime?     @map("last_analyzed_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@unique([unit, vehicleType, goodsType])
  @@map("receiving_time_configs")
}

model UnitGoodsType {
  id          String                 @id @default(cuid())
  unit        ReceivingUnit
  name        String
  emoji       String                 @default("📦")
  baseType    GoodsType              @map("base_type")
  enabled     Boolean                @default(true)
  sortOrder   Int                    @default(0) @map("sort_order")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  deliveries  DeliveryRegistration[]
  timeWindows DeliveryTimeWindow[]

  @@index([unit, baseType])
  @@map("unit_goods_types")
}

model DeliveryTimeWindow {
  id              String         @id @default(cuid())
  unit            ReceivingUnit
  goodsType       GoodsType      @map("goods_type")
  // When set: window belongs to this custom goods type.
  // When null: window is the base-type fallback (used when no custom types are configured).
  unitGoodsTypeId String?        @map("unit_goods_type_id")
  unitGoodsType   UnitGoodsType? @relation(fields: [unitGoodsTypeId], references: [id], onDelete: Cascade)
  label           String?
  startTime       String         @map("start_time")
  endTime         String         @map("end_time")
  enabled         Boolean        @default(true)
  sortOrder       Int            @default(0) @map("sort_order")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([unit, goodsType])
  @@index([unitGoodsTypeId])
  @@map("delivery_time_windows")
}
